generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

model User {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  password  String
  role      Role      @default(USER)
  createdAt DateTime  @default(now())
  bookings  Booking[]
}

model Movie {
  id            Int          @id @default(autoincrement())
  externalId    String       @unique
  title         String
  description   String?
  duration      Int
  genre         String?
  posterUrl     String?
  backdropUrl   String?
  releaseDate   DateTime?
  isPopular     Boolean      @default(false)
  isTopRated    Boolean      @default(false)
  isNowPlaying  Boolean      @default(false)
  isUpcoming    Boolean      @default(false)
  createdAt     DateTime     @default(now())
  projections   Projection[]
}

model Hall {
  id          Int          @id @default(autoincrement())
  name        String
  totalSeats  Int
  projections Projection[]
}

model Projection {
  id        Int       @id @default(autoincrement())
  movieId   Int
  hallId    Int
  startTime DateTime
  price     Float
  movie     Movie     @relation(fields: [movieId], references: [id])
  hall      Hall      @relation(fields: [hallId], references: [id])
  bookings  Booking[]
}

model Booking {
  id           Int        @id @default(autoincrement())
  projectionId Int
  userId       Int
  seatNumber   Int
  ticketCode   String     @unique @default(cuid())
  createdAt    DateTime   @default(now())
  projection   Projection @relation(fields: [projectionId], references: [id])
  user         User       @relation(fields: [userId], references: [id])
}